class Solution {
public:
    long long taskSchedulerII(vector<int>& tasks, int space) {
        
        unordered_map<long long, long long> mp;

        long long days = 0;

        for(int i = 0 ; i < tasks.size(); i++) {

            if(!mp.count(tasks[i])) {
                days++;
                mp[tasks[i]] = days;
            }
            else {
                
                long long expectedDay = days + 1;
                if(expectedDay - mp[tasks[i]] > space) {
                    days++;
                }
                else {
                    days = mp[tasks[i]] + space + 1;
                }

                mp[tasks[i]] = days;

            }

        }

        return days;

    }
};
