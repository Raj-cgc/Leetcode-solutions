class Solution {
public:

    int n;

    bool check(int mid, vector<vector<int>>& tasks) {

        int energyLeft = mid;

        for(auto& task : tasks) {

            int actual = task[0];
            int minimum = task[1];

            if(energyLeft >= minimum) {
                energyLeft -= actual;
            }
            else {
                return false;
            }

        }

        return true;

    }

    int minimumEffort(vector<vector<int>>& tasks) {
        
        n = tasks.size();

        auto comp = [&](vector<int>& a, vector<int>& b) {
            return a[1] - a[0] > b[1] - b[0];
        };

        sort(tasks.begin(), tasks.end(), comp);

        int l = 0;
        int r = 1e9;

        int result = 0;

        while(l <= r) {

            int mid = l + (r-l)/2;

            if(check(mid, tasks)) {
                result = mid;
                r = mid - 1;
            }
            else {
                l = mid + 1;
            }

        }

        return result;

    }
};
