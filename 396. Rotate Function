class Solution {
public:
    int maxRotateFunction(vector<int>& nums) {
        
        int n = nums.size();
        int maxVal = INT_MIN;

        vector<int> F(n);
        int T = accumulate(nums.begin(), nums.end(), 0);

        // for F(0) :
        int sum = 0;
        for(int i = 0 ; i < n ; i++) {
            sum += (i*nums[i]);
        }
        F[0] = sum;

        maxVal = max(maxVal,sum);

        // for rest of the rotations :

        for(int i = 1 ; i < n ; i++) {

            F[i] = F[i-1] + T - (n*nums[n-i]);
            maxVal = max(maxVal, F[i]);

        }

        return maxVal;

    }
};
