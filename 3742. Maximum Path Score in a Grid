class Solution {
public:

    int m, n;
    vector<vector<vector<int>>> dp;

    int solve(int i, int j, int k, vector<vector<int>>& grid) {

        //base case
        if(i >= m || j >= n)
            return -1e9;
        if(k < 0)
            return -1e9;
        if(i == m-1 && j == n-1) {
            if(grid[i][j] == 1)
                k--;
            else if(grid[i][j] == 2)
                k--;
            if(k >= 0)
                return grid[i][j];
            return -1e9;
        }

        if(dp[i][j][k] != -1)
            return dp[i][j][k];

        int maxSum = -1e9;

        if(grid[i][j] == 0) {
            maxSum = max(maxSum, solve(i+1, j, k, grid));
            maxSum = max(maxSum, solve(i, j+1, k, grid));
        }
        else if(grid[i][j] == 1) {
            maxSum = max(maxSum, 1 + solve(i+1, j, k-1, grid));
            maxSum = max(maxSum, 1 + solve(i, j+1, k-1, grid));
        }
        else {
            maxSum = max(maxSum, 2 + solve(i+1, j, k-1, grid));
            maxSum = max(maxSum, 2 + solve(i, j+1, k-1, grid));
        }

        return dp[i][j][k] = maxSum;

    }

    int maxPathScore(vector<vector<int>>& grid, int k) {
        
        m = grid.size();
        n = grid[0].size();
        dp.assign(m+1, vector<vector<int>>(n+1, vector<int>(k+1,-1)));

        int ans = solve(0, 0, k, grid) ;

        return ans < 0 ? -1 : ans;
    }
};
