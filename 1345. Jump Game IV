class Solution {
public:

    unordered_map<int, vector<int>> mp;
    int n;

    int bfs(vector<int>& arr) {

        vector<bool> vis(n, false);
        queue<int> q;
        q.push(0);
        vis[0] = true;

        int level = 0;

        while(!q.empty()) {

            int size = q.size();

            while(size--) {

                int node = q.front();
                q.pop();

                if(node == n-1)
                    return level;

                if(node - 1 >= 0 && !vis[node-1]) {
                    vis[node-1] = true;
                    q.push(node-1);
                }
                if(node + 1 < n && !vis[node+1]) {
                    vis[node+1] = true;
                    q.push(node+1);
                }

                for(auto& v : mp[arr[node]]) {

                    if(v == node)
                        continue;

                    if(!vis[v]) {
                        vis[v] = true;
                        q.push(v);
                    }

                }

                mp[arr[node]].clear();

            }

            level++;

        }

        return -1;

    }

    int minJumps(vector<int>& arr) {

        n = arr.size();
        
        for(int i = 0 ; i < n ; i++) {

            mp[arr[i]].push_back(i);

        }

        return bfs(arr);

    }
};
